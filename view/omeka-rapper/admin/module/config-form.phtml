<script>
document.addEventListener("DOMContentLoaded", () => {
  function getOptionalElement(selector) {
    if (!selector) return null;
    try {
      return document.querySelector(selector);
    } catch (error) {
      console.error(error);
      return null;
    }
  }

  function setStatus(select, message, color) {
    const statusSelector = select.id ? `.omekarapper-model-status[data-for="#${select.id}"]` : "";
    const status = getOptionalElement(statusSelector);
    if (!status) return;
    status.textContent = message || "";
    status.style.color = color || "";
  }

  async function refreshModelSelect(select) {
    if (!select) return;
    const endpoint = select.getAttribute("data-model-endpoint");
    const provider = select.getAttribute("data-model-source");
    const apiKeyInput = getOptionalElement(select.getAttribute("data-api-key-input") || "");
    const baseUrlInput = getOptionalElement(select.getAttribute("data-base-url-input") || "");
    if (!endpoint || !provider || !baseUrlInput) return;

    const baseUrl = (baseUrlInput.value || "").trim();
    const apiKey = apiKeyInput ? (apiKeyInput.value || "").trim() : "";

    if (!baseUrl) {
      setStatus(select, "Enter an endpoint to load models.", "#666");
      return;
    }

    if ((provider === "chatgpt" || provider === "codex" || provider === "claude") && !apiKey) {
      setStatus(select, "Enter an API key to load models.", "#666");
      return;
    }

    if (!/^https?:\/\//i.test(baseUrl)) {
      setStatus(select, "Endpoint must start with http:// or https://", "#b00");
      return;
    }

    const currentValue = select.value;
    const body = new URLSearchParams({
      provider,
      base_url: baseUrl,
      api_key: apiKey
    });

    select.disabled = true;
    setStatus(select, "Loading models...", "#666");
    try {
      const response = await fetch(endpoint, {
        method: "POST",
        headers: { "Content-Type": "application/x-www-form-urlencoded; charset=UTF-8" },
        credentials: "same-origin",
        body
      });
      const raw = await response.text();
      let json;
      try {
        json = JSON.parse(raw);
      } catch (error) {
        throw new Error(raw || `Request failed with status ${response.status}.`);
      }

      if (!response.ok) {
        throw new Error(json.error || `Request failed with status ${response.status}.`);
      }

      if (!json.ok || !Array.isArray(json.models) || !json.models.length) {
        throw new Error(json.error || "No models returned.");
      }

      const models = [...json.models];
      select.innerHTML = "";
      models.forEach((modelName) => {
        const option = document.createElement("option");
        option.value = modelName;
        option.textContent = modelName;
        if (modelName === currentValue) {
          option.selected = true;
        }
        select.appendChild(option);
      });

      if (![...select.options].some((option) => option.selected) && currentValue) {
        const customOption = document.createElement("option");
        customOption.value = currentValue;
        customOption.textContent = currentValue;
        customOption.selected = true;
        select.appendChild(customOption);
      }
      setStatus(select, `Loaded ${models.length} models.`, "#067d17");
    } catch (error) {
      console.error(error);
      setStatus(select, error.message || "Could not load models.", "#b00");
    } finally {
      select.disabled = false;
    }
  }

  document.querySelectorAll("select[data-model-source]").forEach((select) => {
    refreshModelSelect(select);
  });

  document.querySelectorAll(".omekarapper-refresh-models").forEach((button) => {
    button.addEventListener("click", () => {
      const select = getOptionalElement(button.getAttribute("data-target"));
      refreshModelSelect(select);
    });
  });
});
</script>
